{
  "name": "smart-attendance-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "clean": "watchman watch-del-all && rm -rf node_modules && rm -rf .expo && npm cache clean --force",
    "clean:metro": "rm -rf $TMPDIR/metro-* && rm -rf $TMPDIR/haste-* && rm -rf /tmp/metro-* && rm -rf /tmp/haste-*",
    "reset": "npm run clean && npm run clean:metro && npm install && npx expo start -c"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.0.0",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~54.0.30",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.12",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.21",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.9",
    "tailwindcss": "3.3.2",
    "typescript": "~5.9.2"
  }
}
