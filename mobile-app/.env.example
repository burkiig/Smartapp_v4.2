# Copy to .env and fill with real values. NEVER commit .env.

# Backend API base URL — use your server IP/domain (no trailing slash)
# Local network: http://192.168.1.xxx:8000
# Production:   https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://192.168.1.xxx:8000

# Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Dashboard → Settings → API → anon public key
SUPABASE_ANON_KEY=your-anon-jwt-here

# expo.dev → Project → Settings → Project ID
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
