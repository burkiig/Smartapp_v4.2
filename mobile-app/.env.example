# Copy to .env and fill with real values. NEVER commit .env.

# Backend API (use your machine's LAN IP for physical device testing)
EXPO_PUBLIC_API_URL=http://192.168.1.101:8000

# Supabase (client-side anon key only — never put service_role here)
SUPABASE_URL=https://<proje-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...

# EAS Build (optional — from expo.dev project settings)
EXPO_PUBLIC_EAS_PROJECT_ID=
