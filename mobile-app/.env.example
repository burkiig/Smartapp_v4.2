# Mobile App — copy this file to .env and fill in real values
# NEVER commit .env to version control

# Backend API base URL (your server's IP or domain)
EXPO_PUBLIC_API_URL=http://YOUR_SERVER_IP:8000

# Supabase (optional — only needed if using Supabase Auth/Storage)
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Expo Application Services project ID
# Get from: https://expo.dev > your project > settings
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id-here
