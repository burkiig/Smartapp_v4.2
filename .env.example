# Environment Configuration for Smart Attendance System

# ==================== DATABASE CONFIGURATION ====================

# Database Mode: 'json' or 'mongodb'
# Set to 'true' to use MongoDB, 'false' to use JSON files
USE_MONGODB=false

# MongoDB Configuration (only used if USE_MONGODB=true)
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=smart_attendance

# JSON Configuration (only used if USE_MONGODB=false)
JSON_BASE_DIR=static

# ==================== APPLICATION CONFIGURATION ====================

# Flask Secret Key (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=dev-secret-key-change-in-production

# Flask Debug Mode
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=5000

# ==================== CORS CONFIGURATION ====================

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== FACE RECOGNITION CONFIGURATION ====================

# Face recognition tolerance (lower = stricter matching)
FACE_RECOGNITION_TOLERANCE=0.6

# Face detection model: 'hog' (faster) or 'cnn' (more accurate)
FACE_DETECTION_MODEL=hog

# ==================== LOGGING CONFIGURATION ====================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty to disable file logging)
LOG_FILE=logs/smart_attendance.log

# ==================== SECURITY CONFIGURATION ====================

# Rate limiting (requests per hour)
RATE_LIMIT=100

# Session timeout (minutes)
SESSION_TIMEOUT=60
