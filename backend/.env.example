# Copy to .env and fill with real values. NEVER commit .env.
# Do not put production secrets in this file — only placeholders.

HOST=0.0.0.0
PORT=8000
DEBUG=false
ENV=development
TESTING=false

# DATABASE_URL: Supabase Dashboard → Settings → Database (use pooler :6543 in production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt-here
# service_role — backend only, never expose to browsers
SUPABASE_SERVICE_KEY=your-service-role-jwt-here

# python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=generate-a-64-char-hex-string

SECRET_KEY=generate-a-long-random-string-for-jwt-signing
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

ADMIN_EMAIL=admin@youruniversity.edu.tr
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisSecurePassword
ADMIN_NAME=System Administrator

FACE_SIMILARITY_THRESHOLD=0.4
FACE_LIVENESS_THRESHOLD=0.5
DEFAULT_GEOFENCE_RADIUS_M=50
MAX_GPS_ACCURACY_M=30.0
GPS_ACCURACY_THRESHOLD=80.0
QR_TOKEN_TTL_SECONDS=60
LOGIN_RATE_LIMIT=10/minute

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
