# Smart Attendance System — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database (SQLite for local dev/tests, PostgreSQL for Supabase)
DATABASE_URL=sqlite:///./smart_attendance.db
# Supabase direct (port 5432):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# Supabase pooler (port 6543 + transaction mode):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# Supabase API keys
# SUPABASE_URL -> Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=
# SUPABASE_ANON_KEY -> Supabase Dashboard > Settings > API > Project API Keys > anon public
SUPABASE_ANON_KEY=
# ⚠️ SUPABASE_SERVICE_KEY -> Supabase Dashboard > Settings > API > service_role (backend only, never expose to frontend)
SUPABASE_SERVICE_KEY=
# ⚠️ ENCRYPTION_KEY -> generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Security — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_use_a_long_random_string_min_64_chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin Account
ADMIN_EMAIL=admin@youruniversity.edu.tr
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password
ADMIN_NAME=System Administrator

# Face Recognition
FACE_SIMILARITY_THRESHOLD=0.4
FACE_LIVENESS_THRESHOLD=0.5

# Geofencing
DEFAULT_GEOFENCE_RADIUS_M=50
MAX_GPS_ACCURACY_M=30.0

# QR Token TTL (seconds)
QR_TOKEN_TTL_SECONDS=60

# Rate Limiting
LOGIN_RATE_LIMIT=10/minute

# Auth Cookies (httpOnly — tokens are NOT stored in localStorage)
# Set COOKIE_SECURE=true in production (requires HTTPS).
COOKIE_SECURE=false
# "lax" is recommended for most apps. Use "strict" for higher security.
COOKIE_SAMESITE=lax
# Leave empty for localhost. Set to ".yourdomain.com" in production.
COOKIE_DOMAIN=

# Email Notifications (Feature 7: Absent student emails)
# Leave empty to disable email notifications.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
