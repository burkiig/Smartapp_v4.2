# ─────────────────────────────────────────────────────────────────────────────
# Smart Attendance System — Backend Ortam Değişkenleri Şablonu
# Kopyala: cp .env.example .env   →  ardından gerçek değerleri gir.
# .env dosyasını asla versiyona ekleme (git'e)!
# ─────────────────────────────────────────────────────────────────────────────

# ── Sunucu ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENV=production
TESTING=false

# ── Veritabanı ───────────────────────────────────────────────────────────────
# Geliştirme (SQLite):
# DATABASE_URL=sqlite:///./smart_attendance.db
# Üretim (PostgreSQL — Supabase pooler port 6543):
DATABASE_URL=postgresql://postgres.<proje-ref>:<şifre>@aws-<bölge>.pooler.supabase.com:6543/postgres
# Alembic migration için direkt bağlantı (PgBouncer bypass):
# MIGRATION_DATABASE_URL=postgresql://postgres.<proje-ref>:<şifre>@db.<proje-ref>.supabase.co:5432/postgres

# ── Supabase (opsiyonel — storage için) ──────────────────────────────────────
SUPABASE_URL=https://<proje-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...          # Supabase → Settings → API → anon public
SUPABASE_SERVICE_KEY=eyJ...       # Supabase → Settings → API → service_role (gizli!)

# ── Güvenlik ─────────────────────────────────────────────────────────────────
# Üretmek için: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=BURAYA-UZUN-RASTGELE-BIR-STRING-KOY

# Yüz embedding şifreleme (zorunlu — prod):
# Üretmek için: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=BURAYA-32-BYTE-HEX-KOY

# ── JWT ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# Virgülle ayrılmış izin verilen origin'ler
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# ── Admin varsayılanları (ilk başlatmada seed) ────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=BURAYA-GUCLU-BIR-SIFRE-KOY
ADMIN_NAME=System Administrator

# ── Yüz Tanıma ───────────────────────────────────────────────────────────────
# buffalo_l için tipik aralık: 0.3–0.6 (düşük = daha katı)
FACE_SIMILARITY_THRESHOLD=0.4
FACE_LIVENESS_THRESHOLD=0.5

# ── Konum Doğrulama ───────────────────────────────────────────────────────────
DEFAULT_GEOFENCE_RADIUS_M=50
MAX_GPS_ACCURACY_M=30.0
GPS_ACCURACY_THRESHOLD=80.0

# ── QR Kodu ──────────────────────────────────────────────────────────────────
QR_TOKEN_TTL_SECONDS=60

# ── Hız Sınırlama ────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT=10/minute
# Redis bağlantısı (opsiyonel; yoksa in-memory kullanılır — tek worker için yeterli)
# Çok worker/pod ortamında ZORUNLUDUR (JWT blacklist tutarlılığı için de gerekir):
# REDIS_URL=redis://localhost:6379/0

# ── Çerezler ─────────────────────────────────────────────────────────────────
# Üretimde HTTPS varsa true yap:
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Alt domain için: .yourdomain.com
COOKIE_DOMAIN=
